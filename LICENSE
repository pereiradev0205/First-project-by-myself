
#Atividade 1
#Caixa eletrônico inteligente
while True:
    valor = int(input("Digite o valor do saque: R$ "))

    if valor <= 0:
        print("Valor inválido!")

    elif valor > 5000:
        print("Limite excedido!")

    elif valor % 10 != 0:
        print("Digite um valor múltiplo de 10!")

    else:
        nota100 = valor // 100
        valor = valor % 100

        nota50 = valor // 50
        valor = valor % 50

        nota20 = valor // 20
        valor = valor % 20

        nota10 = valor // 10

        print("Saque realizado!")
        print("Notas de 100:", nota100)
        print("Notas de 50:", nota50)
        print("Notas de 20:", nota20)
        print("Notas de 10:", nota10)

    continuar = input("Deseja outro saque? (S/N): ")

    if continuar.upper() != "S":
        break
